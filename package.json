{
  "name": "ethscriptions",
  "version": "0.4.1",
  "license": "MPL-2.0",
  "description": "Library with utility functions for Ethscriptions. Supports for fetching user profiles, filtering ethscriptions, and resolving names & ENS builtin",
  "author": "wgw <wgw@wgw.lol>",
  "homepage": "https://github.com/tunnckoCore/ethscriptions",
  "funding": [
    "https://ko-fi.com/tunnckoCore/commissions",
    "https://github.com/sponsors/tunnckoCore"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tunnckoCore/ethscriptions.git"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./index.js": "./dist/index.js",
    "./index.mjs": "./dist/index.js",
    "./utils": "./dist/utils.js",
    "./utils.js": "./dist/utils.js",
    "./index.ts": "./src/index.ts",
    "./utils.ts": "./src/utils.ts",
    "./types": "./src/types.ts",
    "./types.ts": "./src/types.ts"
  },
  "module": "./dist/index.js",
  "files": [
    "src",
    "dist"
  ],
  "engines": {
    "bun": ">=1.1.30",
    "node": ">=20",
    "npm": "please-use-bun",
    "yarn": "please-use-bun-yarn-is-dead"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "tag": "latest"
  },
  "scripts": {
    "build": "rm -rf dist && bun build src/index.ts src/utils.ts --outdir dist --packages=external",
    "test": "bun run example.ts"
  },
  "dependencies": {
    "cdn-cache-control": "^1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "eslint-config-tunnckocore": "^7.0.1"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "packageManager": "bun@1.1.30"
}
